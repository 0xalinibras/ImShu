{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun", "node"],
    "paths": {
      "@imshu/core": ["./packages/core/src/index.ts"]
    }
  },
  "include": ["apps/**/*", "packages/**/*", "plugins/**/*", "index.ts"],
  "exclude": ["node_modules", "dist"]
}
